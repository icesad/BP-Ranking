# 复制本文件为 .env.local 并填入真实值。.env.local 已被 .gitignore 忽略，绝不要提交。
# —— 所有这里都是占位/示例，不要写真实密钥到本文件 ——

# DeepSeek（估值、评分卡、改进建议、画像合成）。不填则降级为本地模拟。
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# 估值用的深度推理模型（默认 deepseek-reasoner，失败回退 chat）
DEEPSEEK_VALUATION_MODEL=deepseek-reasoner

# Tavily 联网搜索（估值取证、资讯抓取、画像社媒信息）。不填则相关功能为空/降级。
TAVILY_API_KEY=

# GitHub OAuth 登录（在 GitHub Developer settings 建 OAuth App 获取）。
# 回调 URL 须与运行端口一致：http://localhost:3100/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# 会话 cookie 签名密钥：随便一长串随机字符即可（部署/上线务必换成新的随机值）
AUTH_SECRET=

# 可选
# GITHUB_TOKEN=            # 提高 GitHub API 额度（导入可比库/competitor demo 时）
# USD_CNY_RATE=7.2         # 取不到实时汇率时的兜底
# MARKET_TICK_MINUTES=180  # 市场心跳分钟数，0=关闭
